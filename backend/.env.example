# Server
PORT=5000

# Database
MONGO_URI=mongodb://127.0.0.1:27017/booking-system

# JWT
JWT_SECRET=YOUR_JWT_SECRET
JWT_REFRESH_SECRET=YOUR_JWT_REFRESH_SECRET

# Mail
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your_user
MAIL_PASS=your_pass
MAIL_FROM="Booking System" <noreply@example.com>

# Seed accounts (used by: npm run seed)
SEED_ADMIN_NAME=PS5 Admin
SEED_ADMIN_EMAIL=admin@ps5booking.com
SEED_ADMIN_PASSWORD=Admin@123
SEED_USER_NAME=Demo Player
SEED_USER_EMAIL=user@ps5booking.com
SEED_USER_PASSWORD=User@123